# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ALLOWED_CHAT_ID=your_telegram_chat_id

# OpenRouter LLM
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Google Cloud / OAuth
GCP_PROJECT_ID=your_gcp_project_id
PUBSUB_TOPIC_NAME=gmail-notifications
PUBSUB_SUBSCRIPTION_NAME=gmail-notifications-sub
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Web Server
APP_HOSTNAME=https://bot.yourdomain.com
WEB_PORT=8080

# Feature Toggles
ENABLE_PRE_FILTER=true
ARCHIVE_PROCESSED_EMAILS=false

# Database (optional, defaults to /data/accounts.db)
# DB_PATH=/data/accounts.db

# Google Cloud credentials (path to service account JSON key file)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
